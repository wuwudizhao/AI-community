# Local PostgreSQL container settings. Change these values outside source control for shared environments.
POSTGRES_DB=liftoff
POSTGRES_USER=liftoff
POSTGRES_PASSWORD=liftoff_local_only
POSTGRES_PORT=5432

# API runtime
DATABASE_URL=postgresql://liftoff:liftoff_local_only@localhost:5432/liftoff?schema=public
API_PORT=4000
WEB_ORIGIN=http://localhost:3000
WEB_BASE_URL=http://localhost:3000
AUTH_COOKIE_NAME=liftoff_session
ALLOW_GUEST_POSTING=true
SESSION_TTL_HOURS=168
EMAIL_VERIFICATION_TTL_MINUTES=60
MAIL_PROVIDER=resend
MAIL_API_KEY=
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME=Liftoff
MAIL_TIMEOUT_MS=10000

# Web runtime
NEXT_PUBLIC_API_URL=http://localhost:4000/api
